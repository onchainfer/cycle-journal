// ── OPENROUTER SERVICE ───────────────────────────────────────────────────────
// Integration with OpenRouter API for Lilith chat using Gemini 2.0 Flash Lite
// Instructions: Copy this file to anthropic.js and add your OpenRouter API key

import { buildLilithSystemPrompt } from '../components/lilithPrompt.js';

const API_BASE = 'https://openrouter.ai/api/v1/chat/completions';
const MODEL = 'google/gemini-2.0-flash-lite-001';

// 🔑 Replace with your OpenRouter API key
const OPENROUTER_KEY_DEV = 'YOUR_OPENROUTER_KEY_HERE';

/**
 * Send a message to Lilith through OpenRouter API using Gemini 2.0 Flash Lite
 * @param {string} userMessage - The user's message
 * @param {Array} conversationHistory - Array of previous messages
 * @param {Object} userProfile - User's complete profile data
 * @param {Array} dailyLogs - Recent daily logs/notes
 * @param {string} screenContext - 'home', 'cycle', or 'chat'
 * @returns {Promise<string>} Lilith's response
 */
export async function sendMessageToLilith(
    userMessage, 
    conversationHistory = [], 
    userProfile = {}, 
    dailyLogs = [], 
    screenContext = 'chat'
) {
    const rawApiKey = process.env.REACT_APP_OPENROUTER_API_KEY || OPENROUTER_KEY_DEV;
    const apiKey = rawApiKey.trim();
    
    console.log('🚀 Lilith Service Initialized');
    
    if (!apiKey || apiKey === 'YOUR_OPENROUTER_KEY_HERE') {
        console.error('❌ NO VALID API KEY FOUND');
        console.error('💡 SOLUTION: Replace OPENROUTER_KEY_DEV with your real OpenRouter API key');
        throw new Error('Please replace OPENROUTER_KEY_DEV with your actual OpenRouter API key');
    }

    try {
        // Build the system prompt using our enhanced Lilith prompt
        const systemPrompt = buildLilithSystemPrompt(userProfile, dailyLogs, screenContext);
        
        // Convert conversation history to OpenAI format (required by OpenRouter)
        const messages = buildMessageHistory(conversationHistory, userMessage, systemPrompt);

        // Prepare request payload - messages first for optimal processing
        const requestBody = {
            messages: messages,
            model: MODEL,
            max_tokens: 1000,
            temperature: 0.7
        };

        // API call to OpenRouter
        const response = await fetch(API_BASE, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${apiKey}`,
                'HTTP-Referer': 'http://localhost:3000',
                'X-Title': 'Lilith Journal',
            },
            body: JSON.stringify(requestBody)
        });

        if (!response.ok) {
            const errorData = await response.json().catch(() => ({}));
            console.error('OpenRouter API error:', errorData);
            throw new Error(`API request failed: ${response.status}`);
        }

        const data = await response.json();
        
        if (data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content) {
            return data.choices[0].message.content;
        } else {
            console.error('Unexpected API response format:', data);
            throw new Error('Invalid response format from API');
        }

    } catch (error) {
        console.error('Error calling OpenRouter API:', error);
        
        // Return user-friendly error messages
        if (error.message.includes('Missing REACT_APP_OPENROUTER_API_KEY')) {
            return "I can't connect right now — my API key isn't configured. Check your .env file for REACT_APP_OPENROUTER_API_KEY.";
        } else if (error.message.includes('API request failed: 401')) {
            return "Authentication failed. Please check that your OpenRouter API key is valid.";
        } else if (error.message.includes('API request failed: 429')) {
            return "I'm getting too many requests right now. Give me a moment and try again.";
        } else if (error.message.includes('API request failed: 500')) {
            return "Something went wrong on my end. Try again in a moment.";
        } else {
            return "I'm having trouble connecting right now. Check your internet and try again.";
        }
    }
}

/**
 * Builds message history in OpenAI format (required by OpenRouter)
 * Prevents message duplication and optimizes token usage
 * @param {Array} history - Previous conversation messages
 * @param {string} currentMessage - Current user message
 * @param {string} systemPrompt - System prompt to include
 * @returns {Array} Formatted message array for API
 */
function buildMessageHistory(history, currentMessage, systemPrompt) {
    const messages = [];
    
    // Add system message first (OpenAI format)
    messages.push({
        role: 'system',
        content: systemPrompt
    });
    
    // Convert previous messages to OpenAI format
    // Take only the last 8 messages to stay within token limits
    const recentHistory = history.slice(-8);
    
    // Filter out the current message if it's already in history to prevent duplication
    const filteredHistory = recentHistory.filter(msg => 
        !(msg.role === 'user' && (msg.text || msg.content) === currentMessage)
    );
    
    for (const msg of filteredHistory) {
        if (msg.role === 'user') {
            messages.push({
                role: 'user',
                content: msg.text || msg.content
            });
        } else if (msg.role === 'lilith' || msg.role === 'assistant') {
            messages.push({
                role: 'assistant',
                content: msg.text || msg.content
            });
        }
    }
    
    // Add current user message (ensuring no duplication)
    messages.push({
        role: 'user',
        content: currentMessage
    });
    
    return messages;
}

/**
 * Helper function to safely serialize profile data
 * @param {any} value - Profile field value
 * @returns {string|null} Safe string representation
 */
export function safeProfileString(value) {
    if (!value) return null;
    if (typeof value === "string") return value;
    if (Array.isArray(value)) {
        return value.map(v => 
            typeof v === "string" ? v : v.name || v.label || JSON.stringify(v)
        ).join(", ");
    }
    if (typeof value === "object") {
        return value.name || value.label || Object.values(value).join(", ");
    }
    return String(value);
}

/**
 * Creates typing effect simulation for natural conversation flow
 * @param {Function} onUpdate - Callback for each character
 * @param {string} text - Full text to display
 * @param {number} delay - Delay between characters (ms)
 * @returns {Promise} Resolves when typing is complete
 */
export function simulateTyping(onUpdate, text, delay = 30) {
    return new Promise((resolve) => {
        let i = 0;
        const timer = setInterval(() => {
            if (i <= text.length) {
                onUpdate(text.substring(0, i));
                i++;
            } else {
                clearInterval(timer);
                resolve();
            }
        }, delay);
    });
}

/**
 * Get API configuration for debugging
 * @returns {Object} Current API config
 */
export function getAPIConfig() {
    const apiKey = process.env.REACT_APP_OPENROUTER_API_KEY || OPENROUTER_KEY_DEV;
    return {
        model: MODEL,
        hasApiKey: !!apiKey && apiKey !== 'YOUR_OPENROUTER_KEY_HERE',
        endpoint: API_BASE,
        environment: 'Production Ready',
        expectedEnvVar: 'REACT_APP_OPENROUTER_API_KEY or hardcoded OPENROUTER_KEY_DEV',
        keySource: process.env.REACT_APP_OPENROUTER_API_KEY ? 'Environment' : 'Hardcoded',
        apiKeyPreview: apiKey && apiKey !== 'YOUR_OPENROUTER_KEY_HERE' ? apiKey.substring(0, 8) + '...' : 'PLACEHOLDER'
    };
}
